{
  "name": "shanghai-writing-workbench",
  "version": "1.0.0",
  "private": true,
  "description": "上海板块写作工作台 MVP",
  "scripts": {
    "dev": "next dev",
    "dev:all": "node --experimental-strip-types scripts/dev-all.ts",
    "build": "next build",
    "start": "next start",
    "worker": "node --experimental-strip-types --import ./scripts/register-alias.mjs scripts/worker.ts",
    "worker:once": "node --experimental-strip-types --import ./scripts/register-alias.mjs scripts/worker.ts --once",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test:review": "node --experimental-strip-types --import ./scripts/register-alias.mjs --test tests/review-diagnostics.test.mjs tests/writing-quality-continuity-fixtures.test.mjs tests/writing-quality-argument-shapes-fixtures.test.mjs",
    "test:rewrite": "node --experimental-strip-types --import ./scripts/register-alias.mjs --test tests/rewrite-pipeline.test.mjs",
    "test:topic": "node --experimental-strip-types --import ./scripts/register-alias.mjs --test --test-concurrency=1 tests/topic-cocreate-route.test.mjs tests/topic-cocreate-postprocess.test.mjs tests/topic-discovery-route.test.mjs tests/topic-discovery-candidates.test.mjs tests/topic-meta.test.mjs",
    "eval:writing-quality": "node --experimental-strip-types --import ./scripts/register-alias.mjs scripts/evals/run-writing-quality.ts",
    "eval:writing-quality:report": "node --experimental-strip-types --import ./scripts/register-alias.mjs scripts/evals/report-writing-quality.ts",
    "eval:argument-human": "node --no-warnings --experimental-strip-types --import ./scripts/register-alias.mjs scripts/eval-argument-samples.ts",
    "rebuild:sample-action-assets": "node --experimental-strip-types --import ./scripts/register-alias.mjs scripts/rebuild-sample-action-assets.ts",
    "analyze:edit-diffs": "node --experimental-strip-types --import ./scripts/register-alias.mjs scripts/analyze-edit-diffs.ts",
    "import-samples": "python3 scripts/import_wz_samples.py --source-dir wz --db-path data/workbench.db",
    "backfill-project-frames": "python3 scripts/backfill_project_frames.py --db-path data/workbench.db"
  },
  "keywords": [
    "nextjs",
    "sqlite",
    "writing-workbench"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "next": "^16.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.3",
    "playwright": "^1.59.1",
    "typescript": "^6.0.2"
  }
}
